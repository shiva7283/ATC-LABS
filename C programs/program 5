// Yace Program for Arithmetic Expression Evaluation (with Lex Tokenizer)

// File: calc.l (Lexer)
%{
#include "y.tab.h"
%}
%%
[0-9]+ { yylval = atoi(yytext); return NUM; }
[\t ]+ ;
\n     { return 0; }
.      { return yytext[0]; }
%%


// File: calc.y (Parser)
%{
#include<stdio.h>
void yyerror(char *s);
int yylex();
%}
%token NUM
%left '+' '-'
%left '*' '/'
%%
S: E { printf("Result: %d\n", $1); }
E: E '+' E { $$ = $1 + $3; } | E '-' E { $$ = $1 - $3; }
 | E '*' E { $$ = $1 * $3; } | E '/' E { $$ = $1 / $3; }
 | '(' E ')' { $$ = $2; } | NUM { $$ = $1; }
%%
void yyerror(char *s) { printf("Error\n"); }
int main() { yyparse(); return 0; }
